### =====================================================
### INVESTIGADORES
### =====================================================

### GET ALL INVESTIGADORES
GET {{url}}/investigadores
Authorization: Bearer {{token}}

###

### GET INVESTIGADOR BY ID
GET {{url}}/investigadores/1
Authorization: Bearer {{token}}

###

### CREATE INVESTIGADOR
POST {{url}}/investigadores
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nombre": "Israel anjo Chiriboga",
  "cargo": "Director",
  "correo": "ie.aranjo@uta.edu.ec",
  "orcid": "https://orcid.org/0000-0001-5774-1879",
  "facebook": "",
  "linkedin": "",
  "instagram": "",
  "telegram": "",
  "foto": "israel.jpg",
  "biografia": "Investigador en sistemas productivos y gestión de operaciones"
}

###

### UPDATE INVESTIGADOR
PUT {{url}}/investigadores/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nombre": "Isrizado",
  "cargo": "Director REASONS",
  "correo": "ie.naranjo@edu.ec",
  "orcid": "0000-0001-5774-1879",
  "facebook": "",
  "linkedin": "",
  "instagram": "",
  "telegram": "",
  "foto": "israel.jpg",
  "biografia": "Investigador actualizado en optimización y datos"
}

###

### DELETE INVESTIGADOR
DELETE {{url}}/investigadores/1
Authorization: Bearer {{token}}

###

### =====================================================
### PROYECTOS (NUEVO MODELO)
### =====================================================

### GET PROYECTOS
GET {{url}}/proyectos
Authorization: Bearer {{token}}

###

### CREATE PROYECTO (CORREGIDO)
POST {{url}}/proyectos
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Sistema IA Educativo",
  "descripcion": "Sistema de inteligencia artificial para educación personalizada",
  "objetivos": [
    "Mejorar el aprendizaje mediante IA adaptativa"
  ],
  "resultados": "En desarrollo",
  "investigadores": [1]
}

###

### UPDATE PROYECTO
PUT {{url}}/proyectos/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Sistema IA Educativo Mejorado",
  "descripcion": "Proyecto optimizado con IA avanzada",
  "objetivos": "Optimización del aprendizaje inteligente",
  "resultados": "Fase de pruebas",

  "investigadorId": 1,

  "participantes": [1, 2]
}

###
### GET PROYECTO BY ID
GET {{url}}/proyectos/7
Authorization: Bearer {{token}}
### DELETE PROYECTO
DELETE {{url}}/proyectos/1
Authorization: Bearer {{token}}

