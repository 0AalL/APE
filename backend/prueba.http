### =====================================================
### PROYECTOS (NUEVO MODELO)
### =====================================================

### GET PROYECTOS
GET {{url}}/proyectos
Authorization: Bearer {{token}}

###

### CREATE PROYECTO 1
POST {{url}}/proyectos
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Sistema de IA para Educación Personalizada",
  "descripcion": "Desarrollo de un sistema inteligente que adapta el contenido educativo según el perfil y ritmo de aprendizaje del estudiante",
  "objetivos": [
    "Crear modelos de IA adaptativa",
    "Mejorar 40% la retención de conocimiento",
    "Integrar análisis de desempeño en tiempo real"
  ],
  "resultados": "En desarrollo",
  "investigadores": [1, 2]
}

### CREATE PROYECTO 2
POST {{url}}/proyectos
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Optimización de Procesos Empresariales mediante Análisis de Datos",
  "descripcion": "Análisis y optimización de procesos operacionales en empresas utilizando técnicas avanzadas de data mining y machine learning",
  "objetivos": [
    "Reducir costos operacionales en 25%",
    "Implementar dashboard de monitoreo",
    "Capacitar equipos en análisis de datos"
  ],
  "resultados": "Fase 1 completada",
  "investigadores": [1]
}

###

### UPDATE PROYECTO
PUT {{url}}/proyectos/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "titulo": "Sistema IA Educativo Mejorado",
  "descripcion": "Proyecto optimizado con IA avanzada",
  "objetivos": "Optimización del aprendizaje inteligente",
  "resultados": "Fase de pruebas",

  "investigadorId": 1,

  "participantes": [1, 2]
}

